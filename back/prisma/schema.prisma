model preferences_notification {
  utilisateur_id       String       @id @db.Char(36)
  canal_application    Boolean      @default(true)
  canal_email          Boolean      @default(false)
  notif_comptes        Boolean      @default(true)
  notif_articles       Boolean      @default(true)
  notif_messages       Boolean      @default(true)
  notif_projets        Boolean      @default(true)
  notif_demandes_achat Boolean      @default(true)
  notif_livraisons     Boolean      @default(true)
  cree_le              DateTime     @default(now()) @db.Timestamp(6)
  modifie_le           DateTime     @default(now()) @db.Timestamp(6)
  utilisateurs         utilisateurs @relation(fields: [utilisateur_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_preferences_notification")
}

model profils_utilisateur {
  utilisateur_id             String             @id @db.Char(36)
  grade                      String?            @db.VarChar(150)
  institution_affectation_id BigInt?
  est_doctorant              Boolean            @default(false)
  dernier_diplome_libre      String?            @db.VarChar(255)
  niveau_diplome_id          BigInt?
  date_obtention_diplome     DateTime?          @db.Date
  etablissement_diplome      String?            @db.VarChar(255)
  laboratoire_denomination   String?            @db.VarChar(255)
  laboratoire_etablissement  String?            @db.VarChar(255)
  laboratoire_universite     String?            @db.VarChar(255)
  laboratoire_responsable    String?            @db.VarChar(255)
  orcid                      String?            @unique(map: "uq_profils_orcid") @db.VarChar(50)
  equipe_recherche_id        BigInt?
  biographie                 String?            @db.Text
  photo_url                  String?            @db.Text
  cree_le                    DateTime           @default(now()) @db.Timestamp(6)
  modifie_le                 DateTime           @default(now()) @db.Timestamp(6)
  equipes_recherche          equipes_recherche? @relation(fields: [equipe_recherche_id], references: [id], onUpdate: NoAction, map: "fk_profils_equipe")
  institutions               institutions?      @relation(fields: [institution_affectation_id], references: [id], onUpdate: NoAction, map: "fk_profils_institution")
  niveaux_diplome            niveaux_diplome?   @relation(fields: [niveau_diplome_id], references: [id], onUpdate: NoAction, map: "fk_profils_niveau")
  utilisateur                utilisateurs       @relation("profil_utilisateur", fields: [utilisateur_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_profils_utilisateur")

  @@index([equipe_recherche_id], map: "idx_profils_equipe")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model projets {
  id                 BigInt               @id @default(autoincrement())
  titre              String               @db.VarChar(300)
