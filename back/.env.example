# Connexion MySQL
DATABASE_URL="mysql://root:your-password@localhost:3306/lr16cnstn02_db"

# Port d'ecoute de l'API
PORT=4000

# Secret JWT (>= 32 caracteres, idealement 64 caracteres aleatoires)
# Generer avec: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET="REMPLACER-PAR-UN-SECRET-ALEATOIRE-DE-64-CARACTERES-MINIMUM"

# Duree de validite du token d'acces (ex: 8h, 30m, 1d)
JWT_EXPIRES_IN="8h"

# Origines autorisees pour CORS (separer par des virgules si plusieurs)
FRONTEND_URL="http://localhost:4200"

# Nom de l'application
APP_NAME="Plateforme LR16CNSTN02"

# Cle API Google Gemini
GEMINI_API_KEY="your-google-gemini-api-key"

# Environnement (development | production)
NODE_ENV="development"
